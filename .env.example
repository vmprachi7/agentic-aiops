# ── Copy this to .env and fill in values ─────────────────────
# cp .env.example .env

# ── AI (Groq — free tier) ─────────────────────────────────────
# Get from: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your-key-here

# ── GitHub ────────────────────────────────────────────────────
# Create a Personal Access Token with: repo, issues, pull_requests scopes
# https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_your-token-here

# Your GitHub repo (owner/repo)
GITHUB_REPO=vmprachi7/agentic-aiops

# ── Prometheus + Loki (in-cluster URLs) ───────────────────────
# These work automatically when running as a pod in AKS
# For local testing, USE_MOCK_DATA=true instead
PROMETHEUS_URL=http://kube-prometheus-stack-prometheus.monitoring.svc.cluster.local:9090
LOKI_URL=http://loki.monitoring.svc.cluster.local:3100

# ── Agent behaviour ───────────────────────────────────────────
# Set to true to use mock alerts + logs (no Prometheus/Loki needed)
USE_MOCK_DATA=true

# How often to check for new alerts (seconds)
POLL_INTERVAL_SECONDS=60

# How many log lines to fetch per alert
LOKI_LOG_LINES=50

# How far back to look for logs (seconds)
LOKI_LOOKBACK_SECONDS=300

# Which alert severities to act on (comma-separated)
ALERT_SEVERITIES=critical,warning
